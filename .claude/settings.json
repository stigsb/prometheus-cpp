{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-check.sh\"",
            "timeout": 120,
            "statusMessage": "Checking clang-format / clang-tidy on changed files"
          }
        ]
      }
    ]
  }
}
